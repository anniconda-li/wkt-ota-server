# Production must use the externally terminated HTTPS URL.
OTA_PUBLIC_BASE_URL=https://ota.example.com
# Set a long random token; leave empty only for trusted development networks.
OTA_DEVICE_TOKEN=replace-with-a-long-random-token
# Enable only if ML307C firmware cannot set X-Device-Token.
OTA_ALLOW_TOKEN_QUERY=false
OTA_MAX_CHUNK_SIZE=49152
OTA_LOG_LEVEL=INFO
